# =============================================================================
# Nidus — Strix Halo AI Workstation (derivative of base)
# =============================================================================
# Matches the kyuz0 amd-strix-halo-toolboxes host configuration baseline.
# The AI toolboxes themselves run inside Toolbx/Podman containers on top of
# this host image — we do NOT bake ROCm into the host.
# =============================================================================

ARG BASE_IMAGE=localhost/bootc-base:latest
FROM ${BASE_IMAGE}

# ── 1. Strix Halo-specific packages ──────────────────────────────────────────
#
# Only packages not already in base. ROCm and AI frameworks live INSIDE
# the toolbox containers, not on the host.
#
RUN dnf install -y \
    podman \
    toolbox \
    distrobox \
    tuned \
    pciutils \
    usbutils \
    lm_sensors \
    linux-firmware \
    && dnf clean all

# ── 2. Copy configuration overlay ────────────────────────────────────────────
#
# Filesystem-mirror layout under config/ maps directly to /:
#   config/usr/lib/bootc/kargs.d/01-strix-halo.toml   → kernel boot parameters
#   config/usr/lib/udev/rules.d/99-amd-kfd.rules      → GPU device access
#   config/usr/lib/sysusers.d/noctua.conf              → noctua user/group defs
#   config/usr/lib/systemd/system/strix-halo-firstboot.service
#   config/usr/local/bin/strix-halo-firstboot.sh       → first-boot tuned setup
#   config/usr/local/bin/strix-halo-setup-toolboxes.sh → toolbox provisioning
#
COPY config/ /

# ── 3. Create the noctua user ──────────────────────────────────────────────
#
# Materialize sysusers.d entries (including noctua.conf from the overlay)
# into /etc/passwd and /etc/group so the user exists in the image.
# This lets bootc-image-builder / Anaconda apply SSH keys and passwords
# from config.toml without hitting "user does not exist" errors.
#
RUN systemd-sysusers && systemd-tmpfiles --create /usr/lib/tmpfiles.d/noctua.conf

# ── 4. Enable services ───────────────────────────────────────────────────────
RUN systemctl enable tuned strix-halo-firstboot.service

# ── 5. Kernel boot parameter notes ───────────────────────────────────────────
#
# Parameters are declared in /usr/lib/bootc/kargs.d/01-strix-halo.toml and
# applied by bootc at install time and on subsequent upgrades.
#
# For a 128 GB Strix Halo system:
#   amd_iommu=off             — disable IOMMU for lower GPU memory access latency
#   amdgpu.gttsize=131072     — 128 GiB GTT (Graphics Translation Table) in MiB
#   ttm.pages_limit=33554432  — 128 GiB pinned memory limit (pages x 4 KiB)
#
# FUTURE: amdgpu.gttsize is being deprecated upstream in favor of
# ttm.pages_limit / ttm.page_pool_size. On kernels >= 6.16.9 the kernel has
# native UMA fixes and these may not be strictly required, but they are still
# recommended for explicit control.

RUN bootc container lint
