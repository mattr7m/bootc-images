# Nidus ISO installer customizations
#
# The nidus image inherits a default "user" account (UID 1000) from base.
# The %post script below renames it to "noctua", adds GPU group memberships,
# sets credentials, and configures SSH.
#
# Generate a password hash with:
#   python3 -c "import crypt; print(crypt.crypt('yourpassword'))"
#
# Copy this file to config.toml and fill in real values before building:
#   cp config.toml.example config.toml

[customizations.installer.kickstart]
contents = """
%post --log=/var/log/anaconda/ks-post.log
# Hostname
echo 'nidus' > /etc/hostname

# Rename default user → noctua
usermod -l noctua user
groupmod -n noctua user
usermod -d /home/noctua -m noctua
chown noctua:noctua /var/home/noctua

# Fix subordinate UID/GID mapping after rename (usermod -l doesn't update these)
sed -i 's/^user:/noctua:/' /etc/subuid
sed -i 's/^user:/noctua:/' /etc/subgid

# GPU access: promote system groups and add memberships
grep -q '^video:' /etc/group || getent group video >> /etc/group
grep -q '^render:' /etc/group || getent group render >> /etc/group
usermod -aG video,render noctua

# User password
echo 'noctua:$6$rounds=...' | chpasswd -e

# SSH authorized key
mkdir -p /var/home/noctua/.ssh
echo 'ssh-ed25519 AAAA...' >> /var/home/noctua/.ssh/authorized_keys
chmod 700 /var/home/noctua/.ssh
chmod 600 /var/home/noctua/.ssh/authorized_keys
chown -R noctua:noctua /var/home/noctua/.ssh
restorecon -R /var/home/noctua/.ssh
%end
"""
