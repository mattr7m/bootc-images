ARG BASE_IMAGE=localhost/bootc-base:latest
FROM ${BASE_IMAGE}

RUN dnf install -y \
    podman \
    python3 \
    php \
    gcc \
    && dnf clean all

# Claude Code — native binary via official installer
# /root → /var/roothome symlink exists but target is missing in bootc images
RUN mkdir -p /var/roothome && curl -fsSL https://claude.ai/install.sh | bash

COPY config/ /

RUN bootc container lint
