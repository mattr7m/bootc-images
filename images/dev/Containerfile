ARG BASE_IMAGE=localhost/bootc-base:latest
FROM ${BASE_IMAGE}

RUN dnf install -y \
    podman \
    python3 \
    php \
    gcc \
    && dnf clean all

# Claude Code — native binary via official installer
# Installs to /root/.local, then symlink to /usr/local/bin for all users.
# /root → /var/roothome symlink exists but target is missing in bootc images.
RUN mkdir -p /var/roothome && \
    curl -fsSL https://claude.ai/install.sh | bash && \
    ln -sf /var/roothome/.local/bin/claude /usr/local/bin/claude

COPY config/ /

RUN bootc container lint
