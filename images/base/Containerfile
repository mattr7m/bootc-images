FROM quay.io/fedora/fedora-bootc:43

# Copy system configuration
COPY config/ /

# Create default user (UID 1000) from sysusers.d/tmpfiles.d overlay
# systemd-sysusers does not allocate subordinate UIDs/GIDs (unlike useradd),
# so we must explicitly grant a range for rootless podman user namespaces.
RUN systemd-sysusers && systemd-tmpfiles --create /usr/lib/tmpfiles.d/default-user.conf && \
    usermod --add-subuids 100000-165535 --add-subgids 100000-165535 user

# Install core packages
RUN dnf install -y \
    git \
    gh \
    tmux \
    curl \
    rsync \
    wget \
    htop \
    emacs \
    jq \
    && dnf clean all

RUN bootc container lint
